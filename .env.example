## Root .env.example — shared / monorepo-level vars
## Copy to .env and fill in all values.

## ─── API (apps/api) ──────────────────────────────────────────────────────────
PORT=10000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/booking
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_at_least_32_random_characters_too
JWT_ACCESS_EXPIRES_IN=40m
JWT_REFRESH_EXPIRES_IN_DAYS=30
GOOGLE_CLIENT_ID=__set_google_oauth_client_id__
CORS_ORIGINS=http://localhost:3000
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_...
RESEND_API_KEY=re_...
SMTP_FROM="RentPropertyUAE <booking@rentpropertyuae.com>"
SMTP_REPLY_TO=info@rentpropertyuae.com
BRAND_LOGO_URL=https://rentpropertyuae.com/brand/logo.svg
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

## ─── WEB (apps/web) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_ORIGIN=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=__set_google_oauth_client_id__
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=__set_in_local_env__
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
