{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "TodoWrite",
      "Bash",
      "PowerShell",
      "WebFetch",
      "WebSearch",
      "NotebookRead",
      "NotebookEdit",
      "Agent",
      "Bash(npm -v)",
      "Bash(pnpm -v)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./config/credentials.json)",
      "Read(./service-account*.json)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(./secrets/**)",
      "Edit(./credentials/**)",
      "Edit(./config/credentials.json)",
      "Edit(./service-account*.json)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf .git)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fdx*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "PowerShell(Set-ExecutionPolicy *)",
      "PowerShell(Invoke-Expression *)",
      "PowerShell(iex *)",
      "PowerShell(powershell -EncodedCommand *)",
      "PowerShell(pwsh -EncodedCommand *)",
      "PowerShell(Start-Process * -Verb runAs*)",
      "PowerShell(reg add *)",
      "PowerShell(reg delete *)",
      "PowerShell(netsh advfirewall *)",
      "PowerShell(Set-MpPreference *)",
      "PowerShell(format *)",
      "PowerShell(diskpart *)",
      "PowerShell(bcdedit *)",
      "PowerShell(cipher /w*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "defaultShell": "powershell"
}
