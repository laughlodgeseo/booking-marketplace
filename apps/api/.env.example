## ─── CORE ───────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production

## ─── DATABASE ────────────────────────────────────────────────────────────────
# Neon (production): postgresql://user:pass@host/db?sslmode=require&channel_binding=require
# Local:             postgresql://postgres:postgres@localhost:5432/booking
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/booking

## ─── REDIS ───────────────────────────────────────────────────────────────────
# Railway Redis or Upstash in production; localhost for local dev
REDIS_URL=redis://localhost:6379

## ─── JWT AUTH ────────────────────────────────────────────────────────────────
# REQUIRED — must be >= 32 random characters each (never use these placeholders)
JWT_ACCESS_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_at_least_32_random_characters_too
JWT_ACCESS_EXPIRES_IN=40m
JWT_REFRESH_EXPIRES_IN_DAYS=30

## ─── COOKIES (optional fine-tuning) ─────────────────────────────────────────
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_DOMAIN=.rentpropertyuae.com

## ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://rentpropertyuae.vercel.app,http://localhost:3000

## ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=__set_google_oauth_client_id__

## ─── STRIPE ──────────────────────────────────────────────────────────────────
# REQUIRED for payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional — surfaced to clients via API
STRIPE_PUBLISHABLE_KEY=pk_live_...

## ─── EMAIL (Resend) ──────────────────────────────────────────────────────────
# REQUIRED for transactional emails
RESEND_API_KEY=re_...
SMTP_FROM="RentPropertyUAE <booking@rentpropertyuae.com>"
SMTP_REPLY_TO=info@rentpropertyuae.com
BRAND_LOGO_URL=https://rentpropertyuae.com/brand/logo.svg

## ─── CLOUDINARY (media storage) ──────────────────────────────────────────────
# Required for production image/document uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_PROPERTY_MEDIA_FOLDER=booking-marketplace/properties

## ─── FX RATES (optional auto-sync) ──────────────────────────────────────────
FX_PROVIDER=exchangerate-api
FX_PROVIDER_API_KEY=
FX_PROVIDER_URL=https://v6.exchangerate-api.com/v6
FX_CACHE_TTL_SECONDS=86400

## ─── SWAGGER (optional) ──────────────────────────────────────────────────────
# Set to true to expose /docs in production (disabled by default)
# SWAGGER_ENABLED=true
