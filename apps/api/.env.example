PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/booking?schema=public
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me_too
JWT_ACCESS_EXPIRES_IN=40m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# Stripe
STRIPE_SECRET_KEY=__set_in_local_env__
STRIPE_WEBHOOK_SECRET=__set_in_local_env__
# Optional fallback for clients still reading publishable key from API response.
STRIPE_PUBLISHABLE_KEY=__optional_publishable_key__

# Optional FX provider sync (if omitted, admin can set rates manually)
FX_PROVIDER=exchangerate-api
FX_CACHE_TTL_SECONDS=86400
FX_PROVIDER_API_KEY=
FX_PROVIDER_URL=https://v6.exchangerate-api.com/v6

# Cloudinary (optional but recommended in production for persistent media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional unsigned upload preset (if you do not use API key/secret signing)
CLOUDINARY_UPLOAD_PRESET=
# Optional override (default: booking-marketplace/properties)
CLOUDINARY_PROPERTY_MEDIA_FOLDER=

# SMTP (cPanel)
SMTP_HOST=mail.rentpropertyuae.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=booking@rentpropertyuae.com
SMTP_PASS=__set_in_local_env__
SMTP_FROM="RentPropertyUAE <booking@rentpropertyuae.com>"

# Optional
SMTP_REPLY_TO=info@rentpropertyuae.com
BRAND_LOGO_URL=https://rentpropertyuae.com/brand/logo.svg
SMTP_MAX_CONNECTIONS=2
SMTP_MAX_MESSAGES=50
SMTP_RATE_DELTA=1000
SMTP_RATE_LIMIT=5
SMTP_CONNECTION_TIMEOUT_MS=15000
SMTP_GREETING_TIMEOUT_MS=15000
SMTP_SOCKET_TIMEOUT_MS=20000
