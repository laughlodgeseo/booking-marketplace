## ─── API ─────────────────────────────────────────────────────────────────────
# Railway backend URL in production
NEXT_PUBLIC_API_ORIGIN=http://localhost:3001

## ─── SITE ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rentpropertyuae.com

## ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=__set_google_oauth_client_id__

## ─── GOOGLE MAPS ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=__set_in_local_env__
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=__optional_google_map_id__

## ─── STRIPE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

## ─── I18N ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar

## ─── CURRENCY ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPPORTED_CURRENCIES=AED,USD,SAR,EUR,GBP
